{
  "name": "RenderPipeline",
  "namespace": "Rhino.Render",
  "kind": "class",
  "summary": "Provides facilities to a render plug-in for integrating with the standard Rhino render window. Also adds helper functions for processing a render scene. This is the suggested class to use when integrating a renderer with Rhino and maintaining a \u0022standard\u0022 user interface that users will expect.",
  "interfaces": [
    "IDisposable"
  ],
