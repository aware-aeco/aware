  "properties": [
    {
      "name": "CRC",
      "type": "Int32",
      "getter": true,
      "setter": false,
      "summary": "The decal CRC identifies a decal by its state. Multiple decals which would be exactly the same would have the same CRC and are culled from the system. If you store this value with the intention of using it to find the decal again later, you must update your stored value whenever the decal state changes. You can detect when a decal changes by watching for the OnUserDataTransformed event.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/7/html/P_Rhino_Render_Decal_CRC.htm"
    },
    {
      "name": "DecalMapping",
      "type": "DecalMapping",
      "getter": true,
      "setter": false,
      "summary": "Gets the mapping of the decal.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/7/html/P_Rhino_Render_Decal_DecalMapping.htm"
    },
    {
      "name": "DecalProjection",
      "type": "DecalProjection",
      "getter": true,
      "setter": false,
      "summary": "Gets the decal\u0027s projection. Used only when mapping is planar.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/7/html/P_Rhino_Render_Decal_DecalProjection.htm"
    },
    {
      "name": "EndLatitude",
      "type": "Double",
      "getter": true,
      "setter": false,
      "summary": "Gets the end angle of the decal\u0027s arc of latitude or \u0027horizontal sweep\u0027. This is actually a LONGITUDINAL angle. Only used when mapping is cylindrical or spherical.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/7/html/P_Rhino_Render_Decal_EndLatitude.htm"
    },
    {
      "name": "EndLongitude",
      "type": "Double",
      "getter": true,
      "setter": false,
      "summary": "Gets the end angle of the decal\u0027s arc of longitude or \u0027vertical sweep\u0027. This is actually a LATITUDINAL angle. Only used when mapping is spherical.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/7/html/P_Rhino_Render_Decal_EndLongitude.htm"
    },
    {
      "name": "Height",
      "type": "Double",
      "getter": true,
      "setter": false,
      "summary": "Gets the height of the decal. Only used when mapping is cylindrical.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/7/html/P_Rhino_Render_Decal_Height.htm"
