    },
    {
      "name": "Radius",
      "type": "Double",
      "getter": true,
      "setter": false,
      "summary": "Gets the radius of the decal. Only used when mapping is cylindrical or spherical.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/7/html/P_Rhino_Render_Decal_Radius.htm"
