          "optional": false
        },
        {
          "name": "boxCompletelyInFrustum",
          "type": "System.Boolean",
          "doc": "Set to true if the box is completely contained in the pick frustum. When doing a window or crossing pick, you can immediately return a hit if the object\u0027s bounding box is completely inside of the pick frustum.",
