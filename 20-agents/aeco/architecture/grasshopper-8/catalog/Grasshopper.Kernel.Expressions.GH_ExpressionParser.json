          "type": "System.Char",
          "doc": "Char that indicates an opening statement.",
          "optional": false
        },
        {
          "name": "char_close",
          "type": "System.Char",
          "doc": "Char that indicates a closing statement.",
          "optional": false
        },
        {
          "name": "error_at",
          "type": "System.Int32",
          "doc": "The index at which the first error appears or -1 if no error was found.",
          "optional": false
        }
