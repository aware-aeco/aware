      "params": [
        {
          "name": "databaseName",
          "type": "System.String",
          "doc": "The name of the settings server (equals the name of the xml file so it must adhere to FAT, FAT32 and NTFS naming conventions).",
          "optional": false
        },
        {
          "name": "loadSettings",
          "type": "System.Boolean",
