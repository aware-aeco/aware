    {
      "name": "GH_SettingsServer(String)",
      "signature": "public GH_SettingsServer(string databaseName)",
      "summary": "Create a new instance of the GH_SettingsServer class. The server will be associated with a settings xml file in the %ApplicationData%\\Grasshopper\\ directory. If a file with the same name already exists, its settings will be automatically loaded.",
      "params": [
        {
          "name": "databaseName",
          "type": "System.String",
          "doc": "The name of the settings server (equals the name of the xml file so it must adhere to FAT, FAT32 and NTFS naming conventions).",
          "optional": false
        }
      ],
      "returns": null,
      "throws": [],
      "events_related": [],
      "doc_url": "https://raw.githubusercontent.com/mcneel/grasshopper-api-docs/gh-pages/api/grasshopper/html/M_Grasshopper_Kernel_GH_SettingsServer__ctor.htm"
    },
