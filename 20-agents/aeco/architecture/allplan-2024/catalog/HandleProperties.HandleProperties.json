          "default": "True"
        },
        {
          "name": "distance_factor",
          "type": "float",
          "doc": "Factor for property calculation. -1=show negative value in the input control. Multiply the distance between reference and handle point with the factor to get the property value, e.g. 2.0 if the ref_point is a center point.",
