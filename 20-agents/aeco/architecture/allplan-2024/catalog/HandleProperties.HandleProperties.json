          "type": "Optional[Vector3D]",
          "doc": "Direction vector for the handle point movement",
          "optional": true,
          "default": "None"
        },
        {
          "name": "info_text",
          "type": "str",
          "doc": "Information text of the tooltip",
          "optional": true,
          "default": "\u0027\u0027"
        },
        {
          "name": "angle_placement",
          "type": "Optional[AxisPlacement3D]",
          "doc": "Placement for the 3D angle input",
