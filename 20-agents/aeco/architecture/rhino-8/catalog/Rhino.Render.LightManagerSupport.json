    {
      "name": "SetLightSolo",
      "signature": "public virtual bool SetLightSolo(RhinoDoc doc, Guid uuid_light, bool bSolo)",
      "summary": "First checks to see if we are in \u0022solo mode\u0022 - which means that there are any lights that respond \u0022true\u0022 to IsInSoloStorage. If in solo mode: If bSolo = true Sets this light on. If bSolo = false If this is the last light \u0022on\u0022, forces all lights out of solo mode. If there are other lights on, turns this light off. If not in solo mode: If bSolo = true Forces all lights into solo storage and sets this light on. If bSolo = false This shouldn\u0027t happen. Will cause an ASSERT",
      "params": [
        {
          "name": "doc",
          "type": "Rhino.RhinoDoc",
          "doc": "[Missing \u003Cparam name=\u0022doc\u0022/\u003E documentation for \u0022M:Rhino.Render.LightManagerSupport.SetLightSolo(Rhino.RhinoDoc,System.Guid,System.Boolean)\u0022]",
          "optional": false
        },
        {
          "name": "uuid_light",
          "type": "System.Guid",
          "doc": "[Missing \u003Cparam name=\u0022uuid_light\u0022/\u003E documentation for \u0022M:Rhino.Render.LightManagerSupport.SetLightSolo(Rhino.RhinoDoc,System.Guid,System.Boolean)\u0022]",
          "optional": false
        },
        {
          "name": "bSolo",
          "type": "System.Boolean",
          "doc": "[Missing \u003Cparam name=\u0022bSolo\u0022/\u003E documentation for \u0022M:Rhino.Render.LightManagerSupport.SetLightSolo(Rhino.RhinoDoc,System.Guid,System.Boolean)\u0022]",
          "optional": false
        }
      ],
      "returns": {
        "type": "Boolean",
        "doc": "Returns true if action is successful"
      },
      "throws": [],
      "events_related": [],
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/gh-pages/api/RhinoCommon/html/M_Rhino_Render_LightManagerSupport_SetLightSolo.htm"
    },
