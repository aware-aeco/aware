    {
      "name": "Evaluate",
      "signature": "public abstract Object[] Evaluate(IEnumerable args, bool keepTree, out string[] warnings)",
      "summary": "Evaluates the component with a set of arguments. There needs to be an argument for each input param, and each output param gives an entry in the output array.",
      "remarks": "For component that store no state, this method is thread safe.",
      "params": [
        {
          "name": "args",
          "type": "System.Collections.IEnumerable",
          "doc": "The arguments list. Each item is assigned to each input param, in order.",
          "optional": false
        },
        {
          "name": "keepTree",
          "type": "System.Boolean",
          "doc": "A value indicating whether trees should be considered valid inputs, and should be returned. In this case, output variables are not simplified to common types.",
          "optional": false
        },
        {
          "name": "warnings",
          "type": "System.String[]",
          "doc": "A possible list of warnings, or null.",
          "optional": false
        }
      ],
      "returns": {
        "type": "Object[]",
        "doc": "An array of objects, each representing an output result."
