    {
      "name": "CreateCubicBeziers",
      "signature": "public static BezierCurve[] CreateCubicBeziers(Curve sourceCurve, double distanceTolerance, double kinkTolerance)",
      "summary": "Constructs an array of cubic, non-rational Beziers that fit a curve to a tolerance.",
      "params": [
        {
          "name": "sourceCurve",
          "type": "Rhino.Geometry.Curve",
          "doc": "A curve to approximate.",
          "optional": false
        },
        {
          "name": "distanceTolerance",
          "type": "System.Double",
          "doc": "The max fitting error. Use RhinoMath.SqrtEpsilon as a minimum.",
          "optional": false
        },
        {
          "name": "kinkTolerance",
          "type": "System.Double",
          "doc": "If the input curve has a g1-discontinuity with angle radian measure greater than kinkTolerance at some point P, the list of beziers will also have a kink at P.",
          "optional": false
        }
      ],
      "returns": {
        "type": "BezierCurve[]",
        "doc": "A new array of bezier curves. The array can be empty and might contain null items."
