    },
    {
      "name": "FinalMaxFaces",
      "type": "Int32",
      "getter": true,
      "setter": true,
      "summary": "Specifies how many faces the reduction post process should target.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/gh-pages/api/RhinoCommon/html/P_Rhino_FileIO_File3dmDisplacement_FinalMaxFaces.htm"
    },
    {
      "name": "FinalMaxFacesOn",
      "type": "Boolean",
      "getter": true,
      "setter": true,
      "summary": "Specifies whether to perform a mesh reduction as a post process to simplify the result of displacement.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/gh-pages/api/RhinoCommon/html/P_Rhino_FileIO_File3dmDisplacement_FinalMaxFacesOn.htm"
    },
    {
      "name": "InitialQuality",
      "type": "Int32",
      "getter": true,
      "setter": true,
      "summary": "Specifies how densely the object is initially subdivided. The lower the value, the higher the resolution of the displaced mesh.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/gh-pages/api/RhinoCommon/html/P_Rhino_FileIO_File3dmDisplacement_InitialQuality.htm"
    },
    {
      "name": "MappingChannel",
      "type": "Int32",
      "getter": true,
      "setter": true,
      "summary": "Specifies which texture mapping channel is used for the displacement texture.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/gh-pages/api/RhinoCommon/html/P_Rhino_FileIO_File3dmDisplacement_MappingChannel.htm"
    },
    {
      "name": "MeshMemoryLimit",
      "type": "Int32",
      "getter": true,
      "setter": true,
      "summary": "Specifies in megabytes how much memory can be allocated for use by the displacement mesh.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/gh-pages/api/RhinoCommon/html/P_Rhino_FileIO_File3dmDisplacement_MeshMemoryLimit.htm"
    },
    {
      "name": "On",
      "type": "Boolean",
      "getter": true,
      "setter": true,
      "summary": "Specifies whether the displacement feature is enabled or not.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/gh-pages/api/RhinoCommon/html/P_Rhino_FileIO_File3dmDisplacement_On.htm"
    },
    {
      "name": "PostWeldAngle",
      "type": "Double",
      "getter": true,
      "setter": true,
      "summary": "Specifies the maximum angle between face normals of adjacent faces that will get welded together.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/gh-pages/api/RhinoCommon/html/P_Rhino_FileIO_File3dmDisplacement_PostWeldAngle.htm"
    },
    {
      "name": "RefineSensitivity",
      "type": "Double",
      "getter": true,
      "setter": true,
      "summary": "Specifies how sensitive the divider for contrasts is on the displacement texture. Specify 1 to split all mesh edges on each refine step. Specify 0.99 to make even slight contrasts on the displacement texture cause edges to be split. Specifying 0.01 only splits edges where heavy contrast exists.",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/gh-pages/api/RhinoCommon/html/P_Rhino_FileIO_File3dmDisplacement_RefineSensitivity.htm"
    },
    {
      "name": "RefineSteps",
      "type": "Int32",
      "getter": true,
      "setter": true,
      "summary": "Specifies the number of refinement passes",
      "doc_url": "https://raw.githubusercontent.com/mcneel/rhinocommon-api-docs/gh-pages/api/RhinoCommon/html/P_Rhino_FileIO_File3dmDisplacement_RefineSteps.htm"
    },
