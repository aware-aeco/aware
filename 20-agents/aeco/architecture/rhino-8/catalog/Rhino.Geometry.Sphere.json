      "name": "ClosestParameter",
      "signature": "public bool ClosestParameter(Point3d testPoint, out double longitudeRadians, out double latitudeRadians)",
      "summary": "Finds the angle parameters on this sphere that are closest to a test point.",
      "params": [
        {
          "name": "testPoint",
          "type": "Rhino.Geometry.Point3d",
          "doc": "Point to project onto the sphere.",
          "optional": false
        },
        {
          "name": "longitudeRadians",
          "type": "System.Double",
          "doc": "The longitudinal angle (in radians; 0.0 to 2pi) where the sphere approaches testPoint best.",
          "optional": false
        },
        {
          "name": "latitudeRadians",
          "type": "System.Double",
          "doc": "The latitudinal angle (in radians; -0.5pi to \u002B0.5pi) where the sphere approaches testPoint best.",
          "optional": false
        }
      ],
      "returns": {
        "type": "Boolean",
        "doc": "true on success, false on failure. This function will fail if the point it coincident with the sphere center."
      },
