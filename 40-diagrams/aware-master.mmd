%%{init: {'theme':'neutral'}}%%
graph TB

  %% =========================================================
  %% Style classes
  %% =========================================================
  classDef poc        fill:#4ade80,stroke:#16a34a,color:#0f172a,stroke-width:2px
  classDef future     fill:#f1f5f9,stroke:#94a3b8,color:#475569
  classDef substrate  fill:#dbeafe,stroke:#2563eb,color:#0f172a,stroke-width:2px
  classDef meta       fill:#fef3c7,stroke:#d97706,color:#0f172a,stroke-width:2px
  classDef app        fill:#e0e7ff,stroke:#6366f1,color:#0f172a
  classDef commercial fill:#fce7f3,stroke:#be185d,color:#0f172a

  %% =========================================================
  %% Substrate · Apache 2.0
  %% =========================================================
  subgraph SUB["AWARE Substrate · Apache 2.0"]
    direction TB
    Decalog["Decalog<br/>5 structural truths"]:::substrate
    AgentSpec["Agent Spec"]:::substrate
    AppSpec["App Spec"]:::substrate
    CLI["aware CLI<br/>install · run · publish"]:::substrate
    Registry["Registry<br/>GitHub-hosted"]:::substrate

    Decalog --> AgentSpec
    Decalog --> AppSpec
    AgentSpec --> CLI
    AppSpec --> CLI
    CLI --> Registry
  end

  %% =========================================================
  %% Meta primitives — under _core/
  %% =========================================================
  subgraph META["Meta primitives · _core/"]
    direction TB
    Builder["aware-agent-builder ★<br/>any software becomes an agent<br/>--from-dlls / nuget / openapi / com / cli / headers / python"]:::meta
    SkillBuilder["aware-skill-builder ★<br/>author / port / modify / eval skills<br/>wraps Anthropic skill-creator + AWARE conventions"]:::meta
    HtmlReport["html-report ★<br/>render self-contained HTML output"]:::meta
  end

  %% =========================================================
  %% Agents · AECO (the wedge)
  %% =========================================================
  subgraph AGENTS["Agents · AECO is the wedge, not the limit"]
    direction TB

    Eng["Engineering ★<br/>Tekla ★ (curated · 31 skills)<br/>Tekla 2025 ★ (raw · 18 skills · 2,999 cmds · NuGet)<br/>Tekla 2026 ★ (raw · 22 skills · 3,179 cmds · NuGet)<br/>future: ETABS · STAAD · IDEA · Robot · Civil 3D"]:::poc
    Cons["Construction ★<br/>Trimble Connect ★ (7 skills) · Slack · Procore · ACC · Navisworks"]:::poc
    Arch["Architecture ★<br/>Revit 2025 ★ (raw · 46 skills · 7,430 cmds · NuGet)<br/>Revit 2026 ★ (raw · 47 skills · 7,647 cmds · NuGet)<br/>future: ArchiCAD · Rhino+GH · SketchUp · Allplan"]:::poc
    Ops["Operations<br/>IBM Maximo · Autodesk Tandem · Planon · ServiceNow"]:::future
    Cross["Cross-cutting ★<br/>Microsoft 365 ★ (4 skills) · Google Workspace ★ (4 skills) · file · email · excel · think-node"]:::poc
  end

  Other["Other verticals · the substrate doesn't care<br/>(legal · finance · healthcare · …)"]:::future

  %% =========================================================
  %% Apps · plain-text compositions
  %% =========================================================
  subgraph APPS["Apps · plain-text · open source by construction"]
    direction TB
    Refs["Reference apps ★<br/>welded-to-tc.flo (linear · 3 nodes)<br/>qa-drawings-to-tekla.flo (DAG · 7 nodes · fan-in + fan-out)"]:::poc
    Community["Community apps<br/>(exposes-as-agent ecosystem)"]:::future
  end

  %% =========================================================
  %% Commercial layer
  %% =========================================================
  FloLess["FloLess<br/>(commercial visual canvas · separate license)"]:::commercial

  %% =========================================================
  %% Wiring
  %% =========================================================
  Registry --> META
  Registry --> AGENTS

  Builder -. generates .-> Eng
  Builder -. generates .-> Cons
  Builder -. generates .-> Cross
  Builder -. generates .-> Arch
  Builder -. generates .-> Ops
  Builder -. also applies .-> Other

  SkillBuilder -. authors / ports skills for .-> Eng
  SkillBuilder -. authors / ports skills for .-> Cons
  SkillBuilder -. authors / ports skills for .-> Cross

  AGENTS --> Refs
  AGENTS --> Community
  HtmlReport -. consumed by .-> Refs

  Refs -.-> FloLess
  Community -.-> FloLess

  %% =========================================================
  %% Legend
  %% =========================================================
  subgraph LEGEND["Legend"]
    direction LR
    LegPoc["★ v0 POC scope (shipping)"]:::poc
    LegFut["future"]:::future
    LegSub["substrate (free)"]:::substrate
    LegMeta["meta primitive"]:::meta
    LegComm["commercial"]:::commercial
  end
