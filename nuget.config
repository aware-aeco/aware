<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Repo-local NuGet configuration for aware-aeco.

    `<clear />` drops every package source inherited from the machine-global
    %AppData%\NuGet\NuGet.Config. That global config lists private ScaffPlan
    Azure DevOps feeds (a separate, unrelated product) which require auth and
    return HTTP 401 in clean shells / CI — breaking `dotnet restore` for this
    repo even though nothing here depends on them.

    All aware-aeco .NET dependencies (the cli-sidecar) are public on nuget.org,
    so pinning that single source makes `dotnet build cli-sidecar -c Release`
    work with no extra flags. This file does NOT modify the global config or
    affect ScaffPlan builds.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
